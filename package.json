{
  "name": "hono-template",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "bunx auth@latest generate --config=src/lib/auth/server.ts --output=src/server/database/schemas/auth.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/stripe": "^1.6.9",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/react-renderer": "^1.0.1",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.25.3",
    "@nanostores/react": "^1.1.0",
    "@nanostores/router": "^1.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-form": "^1.29.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "lucide-react": "^1.11.0",
    "nanostores": "^1.3.0",
    "react": "npm:@hono/react-compat",
    "react-dom": "npm:@hono/react-compat",
    "shadcn": "^4.5.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.34.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.0",
    "vite": "^6.4.2",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "^4.86.0"
  }
}
